<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN 2.0//EN"
        "http://www.springframework.org/dtd/spring-beans-2.0.dtd">
<beans>

    <!-- Engine Bean -->
    <bean id="engine" class="com.tka.Engine">

        <property name="company" value="Tata"/>

        <property name="cc" value="1200"/>

    </bean>

    <!-- Car Bean -->
    <bean id="car" class="com.tka.Car">

        <property name="carId" value="101"/>

        <property name="carName" value="Nexon"/>

        <property name="engine" ref="engine"/>

    </bean>

</beans>
